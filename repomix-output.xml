  href: string;
  accent: string;
};

export type ProfileWorkOffering = {
  title: string;
  description: string;
};

export type ProfileWorkWithMeCopy = {
  title: string;
  intro: string;
  pricing: string;
  offerings: ProfileWorkOffering[];
};

export type ProfileCategoryDefinition = {
  id: ProfileCategoryId;
  title: string;
  description: string;
  glyph?: ProfileGlyph;
