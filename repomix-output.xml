export type SearchTreeChild = {
  kind: "child";
  id: string;
  title: string;
  description?: string;
  href: string;
  type: "post" | "project" | "page";
  tags?: string[];
  date?: string;
  blog: BlogPost;
};

export type SearchTreeParent = {
  kind: "parent";
  id: ProfileCategoryId;
  title: string;
  description: string;
  glyph?: ProfileGlyph;
  children: SearchTreeChild[];
};

