{
  "name": "next",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prepare": "panda codegen",
    "test": "playwright test",
    "typecheck": "tsc --noEmit",
    "generate-insight": "tsx automation/repo-insight/cli/generate-insight.ts",
    "generate-insight:force": "tsx automation/repo-insight/cli/generate-insight.ts --force",
    "aggregate-insights": "tsx automation/repo-insight/cli/aggregate-insights.ts",
    "aggregate-insights:dry-run": "tsx automation/repo-insight/cli/aggregate-insights.ts --dry-run",
    "secrets:setup": "tsx automation/github-secrets/setup.ts",
    "automation:generate-workflows": "tsx automation/generate-workflows.ts",
    "automation:check-workflows": "tsx automation/check-workflows.ts",
    "automation:actionlint": "if command -v actionlint >/dev/null 2>&1; then actionlint .github/workflows/*.yml; else nix develop --command actionlint .github/workflows/*.yml; fi",
    "insight:taste-profile": "tsx automation/repo-insight/cli/build-taste-profile.ts",
    "insight:check": "tsx automation/repo-insight/cli/check.ts",
    "ci:automation": "pnpm automation:check-workflows && pnpm automation:actionlint && pnpm typecheck && pnpm insight:check",
    "vercel:login": "vercel login",
    "vercel:link": "vercel link",
    "vercel:pull": "vercel pull --yes",
    "vercel:pull:preview": "vercel pull --yes --environment=preview",
    "vercel:pull:prod": "vercel pull --yes --environment=production",
    "vercel:build": "vercel build",
    "vercel:build:prod": "vercel build --prod",
    "deploy:preview": "vercel build && vercel deploy --prebuilt",
    "deploy:prod": "vercel build --prod && vercel deploy --prebuilt --prod",
    "deploy": "pnpm deploy:prod",
    "clean:vercel": "rm -rf .vercel/output"
  },
  "dependencies": {
    "@apple/highlightjs-pkl": "^1.0.1",
    "@cursor/sdk": "^1.0.12",
    "@fortawesome/fontawesome-svg-core": "^6.4.2",
    "@fortawesome/free-brands-svg-icons": "^6.4.2",
    "@fortawesome/free-solid-svg-icons": "^6.4.2",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@mdx-js/loader": "^2.3.0",
    "@next/mdx": "^13.5.5",
    "@types/unist": "^3.0.3",
    "@vercel/analytics": "^1.6.1",
    "@xstate/react": "^6.0.0",
    "@zodyac/zod-mongoose": "^1.1.2",
    "framer-motion": "^12.29.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "next-mdx-remote": "^6.0.0",
    "prism-themes": "^1.9.0",
    "react-inlinesvg": "^4.2.0",
    "rehype-highlight": "^7.0.2",
    "rehype-mdx-code-props": "^1.0.0",
    "rehype-prism-plus": "^2.0.1",
    "rehype-raw": "^7.0.0",
    "unist": "^0.0.1",
    "unist-util-visit": "^5.1.0",
    "vercel": "^50.22.0",
    "webpack": "^5.89.0",
    "xstate": "^5.24.0"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@pandacss/dev": "^1.6.1",
    "@playwright/test": "1.54.1",
    "@svgr/webpack": "^8.1.0",
    "@types/node": "^20.8.7",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8.51.0",
    "eslint-config-next": "^14.1.4",
    "next": "^14.2.1",
    "npm-run-all": "^4.1.5",
    "puppeteer": "^23.11.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsx": "^4.21.0",
    "typescript": "*",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  }
}
